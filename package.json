{
    "name": "werewolf-frontend",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "start:e2e": "ng serve --configuration e2e --port 4200",
        "build": "ng build",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:style": "stylelint \"src/**/*.scss\"",
        "lint:style:fix": "stylelint \"src/**/*.scss\" --fix",
        "prepare": "husky"
    },
    "private": true,
    "packageManager": "npm@10.9.8",
    "engines": {
        "node": "22.22.3"
    },
    "dependencies": {
        "@angular/common": "^22.0.0",
        "@angular/compiler": "^22.0.0",
        "@angular/core": "^22.0.7",
        "@angular/forms": "^22.0.0",
        "@angular/platform-browser": "^22.0.0",
        "@angular/router": "^22.0.0",
        "@microsoft/signalr": "^8.0.0",
        "@ngx-translate/core": "^18.0.0",
        "@ngx-translate/http-loader": "^18.0.0",
        "gsap": "^3.12.5",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^22.0.6",
        "@angular/cli": "^22.0.6",
        "@angular/compiler-cli": "^22.0.0",
        "@playwright/test": "^1.61.1",
        "@types/node": "^26.1.1",
        "angular-eslint": "^22.0.0",
        "autoprefixer": "^10.4.21",
        "eslint": "^9.39.5",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "jsdom": "^28.0.0",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.6",
        "prettier": "^3.8.1",
        "stylelint": "^17.14.0",
        "stylelint-config-prettier-scss": "^1.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "tailwindcss": "^3.4.17",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.63.0",
        "vitest": "^4.0.8"
    },
    "lint-staged": {
        "*.{ts,html}": [
            "eslint --fix"
        ],
        "*.scss": [
            "stylelint --fix"
        ],
        "*.{ts,html,js,mjs,cjs,json,css,scss,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
